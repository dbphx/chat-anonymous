# Copy to .env and adjust. Docker Compose loads .env for variable substitution.
# Used by backend on first boot when no admin user exists yet (see BootstrapDefaultAdmin).

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Frontend (optional). For local `npm start`, leave unset to use package.json "proxy"
# to http://127.0.0.1:8081 (relative /api/* requests). Docker Compose sets this explicitly.
# REACT_APP_BACKEND_URL=http://localhost:8081
